# Database
# Never commit real credentials. Copy this file to .env.local for local development.
DATABASE_HOST=
DATABASE_PORT=3306
DATABASE_NAME=
DATABASE_USER=
DATABASE_PASSWORD=

# Application secrets
# Generate strong random values per environment.
APP_ENCRYPTION_KEY=
SESSION_SECRET=

# Environment
NODE_ENV=development
APP_BASE_URL=http://127.0.0.1:3000

# OAuth providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
